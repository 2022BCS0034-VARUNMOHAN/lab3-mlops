pipeline {
    agent any

    environment {
        IMAGE_NAME = "varuna10/varunmohanbcs34-wine-quality:latest"
        CONTAINER_NAME = "wine_test_container"
        NETWORK_NAME = "wine_net"
        PORT = "8000"
    }

    stages {

        stage('Create Network') {
            steps {
                sh '''
                docker network inspect $NETWORK_NAME >/dev/null 2>&1 || docker network create $NETWORK_NAME
                '''
            }
        }

        stage('Pull Docker Image') {
            steps {
                sh 'docker pull $IMAGE_NAME'
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker rm -f $CONTAINER_NAME || true

                docker run -d \
                  --network $NETWORK_NAME \
                  --name $CONTAINER_NAME \
                  -p 8000:8000 \
                  $IMAGE_NAME

                docker ps
                '''
            }
        }

        stage('Wait for API') {
            steps {
                sh '''
                echo "Checking API readiness..."

                for i in $(seq 1 30)
                do
                    status=$(curl -s -o /dev/null -w "%{http_code}" http://wine_test_container:8000/health || true)

                    if [ "$status" = "200" ]; then
                        echo "API is ready!"
                        exit 0
                    fi

                    echo "Not ready yet... attempt $i"
                    sleep 2
                done

                echo "API failed to start"
                docker logs wine_test_container
                exit 1
                '''
            }
        }

        stage('Send Valid Request') {
            steps {
                sh '''
                curl -f -X POST http://$CONTAINER_NAME:8000/predict \
                -H "Content-Type: application/json" \
                -d @tests/valid_input.json > response.json
                '''
            }
        }

        stage('Validate Response') {
            steps {
                sh '''
                echo "Model Response:"
                cat response.json

                echo "Validating output..."
                grep "wine_quality" response.json

                # ensure it is numeric
                value=$(grep -o '[0-9]\\+' response.json | head -n 1)

                if [ -z "$value" ]; then
                    echo "Prediction invalid!"
                    exit 1
                fi

                echo "Prediction OK: $value"
                '''
            }
        }

        stage('Send Invalid Request') {
            steps {
                sh '''
                echo "Testing bad input validation..."

                curl -s -o /dev/null -w "%{http_code}" \
                -X POST http://$CONTAINER_NAME:8000/predict \
                -H "Content-Type: application/json" \
                -d @tests/invalid_input.json | grep -E "422|400"
                '''
            }
        }
    }

    post {
        always {
            sh 'docker rm -f $CONTAINER_NAME || true'
            sh 'docker network rm $NETWORK_NAME || true'
        }
    }
}